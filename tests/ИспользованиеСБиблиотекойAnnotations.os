#Использовать ".."
#Использовать annotations
#Использовать asserts

// Тест проверяет, что при использовании autumn вместе с библиотекой annotations
// не возникает ошибки "Аннотация с именем 'Аннотация' уже зарегистрирована в контейнере"

&Тест
Процедура МожноСоздатьПоделкуСЗагруженнойБиблиотекойAnnotations() Экспорт
// Дано
// Библиотека annotations уже загружена (см. #Использовать annotations выше)

// Когда
// Создаем Поделку, которая должна просканировать все известные типы,
// включая АннотацияАннотация из библиотеки annotations
Поделка = Новый Поделка();

// Тогда
// Не должно быть исключения
Ожидаем.Что(Поделка).Не_().Равно(Неопределено);
КонецПроцедуры

&Тест
Процедура МожноЗапуститьПриложениеСЗагруженнойБиблиотекойAnnotations() Экспорт
// Дано
Поделка = Новый Поделка();

// Когда
// Запускаем приложение
Поделка.ЗапуститьПриложение();

// Тогда
// Не должно быть исключения
Ожидаем.Что(Поделка).Не_().Равно(Неопределено);
КонецПроцедуры
