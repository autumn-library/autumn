#Использовать asserts
#Использовать "../../src"
#Использовать "../ОшибочныеКлассы/ВалидацияDTOЗаполнено"

Перем _СтарыйТекущийКаталог;

Процедура ПередЗапускомТеста() Экспорт
	_СтарыйТекущийКаталог = ТекущийКаталог();
КонецПроцедуры

Процедура ПослеЗапускаТеста() Экспорт
	УстановитьТекущийКаталог(_СтарыйТекущийКаталог);
КонецПроцедуры

// КП-2.4: Валидация &Заполнено — исключение при пустом обязательном поле
&Тест
Процедура ВалидацияЗаполненоВыбрасываетИсключение() Экспорт

	// Дано — конфиг без значения для обязательного поля, у поля дефолт ""
	ВалидируемыеПараметры = Новый Соответствие;
	// ОбязательноеПоле не указано — используется дефолт ""

	Данные = Новый Соответствие;
	Данные.Вставить("ВалидируемыеПараметры", ВалидируемыеПараметры);

	КаталогВременный = ПолучитьИмяВременногоФайла();
	СоздатьКаталог(КаталогВременный);
	ИмяФайла = ОбъединитьПути(КаталогВременный, "autumn-properties.json");
	Запись = Новый ЗаписьJSON();
	Запись.ОткрытьФайл(ИмяФайла);
	ЗаписатьJSON(Запись, Данные);
	Запись.Закрыть();

	УстановитьТекущийКаталог(КаталогВременный);

	// Когда
	БылаОшибка = Ложь;

	Попытка
		Поделка = Новый Поделка(); // BSLLS:UnusedLocalVariable-off
	Исключение
		БылаОшибка = Истина;
		Ожидаем.Что(ИнформацияОбОшибке().Описание, "Сообщение об ошибке")
			.Содержит("Нарушение валидации DTO ""dto_СЗаполнено""");
	КонецПопытки;

	// Тогда
	Ожидаем.Что(БылаОшибка, "DTO с незаполненным обязательным полем не должно создаваться без ошибки").ЭтоИстина();

КонецПроцедуры
