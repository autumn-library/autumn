#Использовать asserts
#Использовать "../../src"
#Использовать "../ОшибочныеКлассы/ВалидацияDTOДиапазон"

Перем _СтарыйТекущийКаталог;

Процедура ПередЗапускомТеста() Экспорт
	_СтарыйТекущийКаталог = ТекущийКаталог();
КонецПроцедуры

Процедура ПослеЗапускаТеста() Экспорт
	УстановитьТекущийКаталог(_СтарыйТекущийКаталог);
КонецПроцедуры

// КП-2.5: Валидация &Минимум/&Максимум — исключение при нарушении диапазона
&Тест
Процедура ВалидацияДиапазонаВыбрасываетИсключение() Экспорт

	// Дано — конфиг со значением 0, нарушающим &Минимум(1)
	ДиапазонПараметры = Новый Соответствие;
	ДиапазонПараметры.Вставить("ПортСервера", 0);

	Данные = Новый Соответствие;
	Данные.Вставить("ДиапазонПараметры", ДиапазонПараметры);

	КаталогВременный = ПолучитьИмяВременногоФайла();
	СоздатьКаталог(КаталогВременный);
	ИмяФайла = ОбъединитьПути(КаталогВременный, "autumn-properties.json");
	Запись = Новый ЗаписьJSON();
	Запись.ОткрытьФайл(ИмяФайла);
	ЗаписатьJSON(Запись, Данные);
	Запись.Закрыть();

	УстановитьТекущийКаталог(КаталогВременный);

	// Когда
	Поделка = Новый Поделка();
	Поделка.ЗапуститьПриложение();
	Желудь = Поделка.НайтиЖелудь("dto_СДиапазоном");

	// Тогда — валидация не позволяет создать бин с нарушением ограничений
	Ожидаем.Что(Желудь, "DTO с нарушением валидации диапазона не должно создаваться").Равно(Неопределено);

КонецПроцедуры
