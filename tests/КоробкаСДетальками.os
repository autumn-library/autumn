#Использовать ".."
#Использовать asserts
#Использовать "./ТестКлассыDTO"

Перем _СтарыйТекущийКаталог;

Процедура ПередЗапускомТеста() Экспорт
	_СтарыйТекущийКаталог = ТекущийКаталог();
КонецПроцедуры

Процедура ПослеЗапускаТеста() Экспорт
	УстановитьТекущийКаталог(_СтарыйТекущийКаталог);
КонецПроцедуры

// КП-2.1: DTO заполняется из конфига через Поделку
&Тест
Процедура DTOЗаполняетсяИзКонфига() Экспорт

	// Дано
	ПараметрыПодключения = Новый Соответствие;
	ПараметрыПодключения.Вставить("АдресСервера", "test-server");
	ПараметрыПодключения.Вставить("ПортСервера", 3306);

	КаталогНастроек = СоздатьКонфигВоВременномКаталоге(ПараметрыПодключения, "ПараметрыПодключения");
	УстановитьТекущийКаталог(КаталогНастроек);

	// Когда
	Поделка = Новый Поделка();
	Поделка.ЗапуститьПриложение();
	Желудь = Поделка.НайтиЖелудь("dto_НастройкиПодключения");

	// Тогда
	Ожидаем.Что(Желудь.АдресСервера, "АдресСервера").Равно("test-server");
	Ожидаем.Что(Желудь.ПортСервера, "ПортСервера").Равно(3306);

КонецПроцедуры

// КП-2.2: DTO инжектится в потребителя через &Пластилин
&Тест
Процедура DTOИнжектитсяВПотребителя() Экспорт

	// Дано
	ПараметрыПодключения = Новый Соответствие;
	ПараметрыПодключения.Вставить("АдресСервера", "test-server");
	ПараметрыПодключения.Вставить("ПортСервера", 3306);

	КаталогНастроек = СоздатьКонфигВоВременномКаталоге(ПараметрыПодключения, "ПараметрыПодключения");
	УстановитьТекущийКаталог(КаталогНастроек);

	// Когда
	Поделка = Новый Поделка();
	Поделка.ЗапуститьПриложение();
	Потребитель = Поделка.НайтиЖелудь("потребительDTO");

	// Тогда
	Настройки = Потребитель.ПолучитьНастройки();
	Ожидаем.Что(Настройки, "Настройки не должны быть Неопределено").Не_().Равно(Неопределено);
	Ожидаем.Что(Настройки.АдресСервера, "АдресСервера потребителя").Равно("test-server");
	Ожидаем.Что(Настройки.ПортСервера, "ПортСервера потребителя").Равно(3306);

КонецПроцедуры

// КП-2.3: Дефолты применяются при отсутствии ключа в конфиге
&Тест
Процедура ДефолтыПрименяютсяПриОтсутствииКлюча() Экспорт

	// Дано
	ПараметрыПодключения = Новый Соответствие;
	ПараметрыПодключения.Вставить("АдресСервера", "test-server");
	// ПортСервера намеренно не указан — должен быть дефолт 8080

	КаталогНастроек = СоздатьКонфигВоВременномКаталоге(ПараметрыПодключения, "ПараметрыПодключения");
	УстановитьТекущийКаталог(КаталогНастроек);

	// Когда
	Поделка = Новый Поделка();
	Поделка.ЗапуститьПриложение();
	Желудь = Поделка.НайтиЖелудь("dto_НастройкиПодключения");

	// Тогда
	Ожидаем.Что(Желудь.АдресСервера, "АдресСервера из конфига").Равно("test-server");
	Ожидаем.Что(Желудь.ПортСервера, "ПортСервера должен быть дефолтным").Равно(8080);

КонецПроцедуры

// КП-2.4: Вложенный DTO заполняется из конфига с аннотацией &ВложенныйДТО
&Тест
Процедура ВложенныйDTOЗаполняетсяИзКонфига() Экспорт

	// Дано
	Репликация = Новый Соответствие;
	Репликация.Вставить("Включена", Истина);
	Репликация.Вставить("адрес_реплики", "replica.example.com");
	Репликация.Вставить("ПортРеплики", 5444);

	ПараметрыСервера = Новый Соответствие;
	ПараметрыСервера.Вставить("АдресСервера", "prod-server");
	ПараметрыСервера.Вставить("ПортСервера", 9090);
	ПараметрыСервера.Вставить("Репликация", Репликация);

	КаталогНастроек = СоздатьКонфигВоВременномКаталоге(ПараметрыСервера, "ПараметрыСервера");
	УстановитьТекущийКаталог(КаталогНастроек);

	// Когда
	Поделка = Новый Поделка();
	Поделка.ЗапуститьПриложение();
	Желудь = Поделка.НайтиЖелудь("dto_НастройкиСервера");

	// Тогда
	Ожидаем.Что(Желудь.АдресСервера, "АдресСервера").Равно("prod-server");
	Ожидаем.Что(Желудь.ПортСервера, "ПортСервера").Равно(9090);
	Ожидаем.Что(Желудь.Репликация, "Репликация не должна быть Неопределено").Не_().Равно(Неопределено);
	Ожидаем.Что(Желудь.Репликация.Включена, "Включена").Равно(Истина);
	Ожидаем.Что(Желудь.Репликация.АдресРеплики, "АдресРеплики (через синоним)").Равно("replica.example.com");
	Ожидаем.Что(Желудь.Репликация.ПортРеплики, "ПортРеплики").Равно(5444);

КонецПроцедуры

// КП-2.5: Дефолты вложенного DTO при отсутствии ключей
&Тест
Процедура ДефолтыВложенногоDTOПрименяются() Экспорт

	// Дано — конфиг без вложенных ключей вообще
	ПараметрыСервера = Новый Соответствие;
	ПараметрыСервера.Вставить("АдресСервера", "test-server");

	КаталогНастроек = СоздатьКонфигВоВременномКаталоге(ПараметрыСервера, "ПараметрыСервера");
	УстановитьТекущийКаталог(КаталогНастроек);

	// Когда
	Поделка = Новый Поделка();
	Поделка.ЗапуститьПриложение();
	Желудь = Поделка.НайтиЖелудь("dto_НастройкиСервера");

	// Тогда
	Ожидаем.Что(Желудь.АдресСервера, "АдресСервера из конфига").Равно("test-server");
	Ожидаем.Что(Желудь.ПортСервера, "ПортСервера дефолт").Равно(8080);
	Ожидаем.Что(Желудь.Репликация, "Репликация не должна быть Неопределено").Не_().Равно(Неопределено);
	Ожидаем.Что(Желудь.Репликация.Включена, "Включена дефолт").Равно(Ложь);
	Ожидаем.Что(Желудь.Репликация.ПортРеплики, "ПортРеплики дефолт").Равно(5433);

КонецПроцедуры

// КП-2.6: Вложенный DTO инжектится в потребителя через &Пластилин
&Тест
Процедура ВложенныйDTOИнжектитсяВПотребителя() Экспорт

	// Дано
	Репликация = Новый Соответствие;
	Репликация.Вставить("Включена", Истина);
	Репликация.Вставить("адрес_реплики", "replica.local");

	ПараметрыСервера = Новый Соответствие;
	ПараметрыСервера.Вставить("АдресСервера", "injected-server");
	ПараметрыСервера.Вставить("Репликация", Репликация);

	КаталогНастроек = СоздатьКонфигВоВременномКаталоге(ПараметрыСервера, "ПараметрыСервера");
	УстановитьТекущийКаталог(КаталогНастроек);

	// Когда
	Поделка = Новый Поделка();
	Поделка.ЗапуститьПриложение();
	Потребитель = Поделка.НайтиЖелудь("потребительВложенногоDTO");

	// Тогда
	Настройки = Потребитель.ПолучитьНастройки();
	Ожидаем.Что(Настройки, "Настройки не Неопределено").Не_().Равно(Неопределено);
	Ожидаем.Что(Настройки.АдресСервера, "АдресСервера потребителя").Равно("injected-server");
	Ожидаем.Что(Настройки.Репликация.Включена, "Включена у потребителя").Равно(Истина);
	Ожидаем.Что(Настройки.Репликация.АдресРеплики, "АдресРеплики у потребителя").Равно("replica.local");

КонецПроцедуры

Функция СоздатьКонфигВоВременномКаталоге(ДанныеПрефикса, Префикс)

	Данные = Новый Соответствие;
	Данные.Вставить(Префикс, ДанныеПрефикса);

	КаталогВременный = ПолучитьИмяВременногоФайла();
	СоздатьКаталог(КаталогВременный);

	ИмяФайла = ОбъединитьПути(КаталогВременный, "autumn-properties.json");
	Запись = Новый ЗаписьJSON();
	Запись.ОткрытьФайл(ИмяФайла);
	ЗаписатьJSON(Запись, Данные);
	Запись.Закрыть();

	Возврат КаталогВременный;

КонецФункции
