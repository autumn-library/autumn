#Использовать ".."
#Использовать asserts
#Использовать "./ТестКлассыDTO"

Перем _СтарыйТекущийКаталог;

Процедура ПередЗапускомТеста() Экспорт
	_СтарыйТекущийКаталог = ТекущийКаталог();
КонецПроцедуры

Процедура ПослеЗапускаТеста() Экспорт
	УстановитьТекущийКаталог(_СтарыйТекущийКаталог);
КонецПроцедуры

// КП-2.1: DTO заполняется из конфига через Поделку
&Тест
Процедура DTOЗаполняетсяИзКонфига() Экспорт

	// Дано
	ПараметрыПодключения = Новый Соответствие;
	ПараметрыПодключения.Вставить("АдресСервера", "test-server");
	ПараметрыПодключения.Вставить("ПортСервера", 3306);

	КаталогНастроек = СоздатьКонфигВоВременномКаталоге(ПараметрыПодключения, "ПараметрыПодключения");
	УстановитьТекущийКаталог(КаталогНастроек);

	// Когда
	Поделка = Новый Поделка();
	Поделка.ЗапуститьПриложение();
	Желудь = Поделка.НайтиЖелудь("dto_НастройкиПодключения");

	// Тогда
	Ожидаем.Что(Желудь.АдресСервера, "АдресСервера").Равно("test-server");
	Ожидаем.Что(Желудь.ПортСервера, "ПортСервера").Равно(3306);

КонецПроцедуры

// КП-2.2: DTO инжектится в потребителя через &Пластилин
&Тест
Процедура DTOИнжектитсяВПотребителя() Экспорт

	// Дано
	ПараметрыПодключения = Новый Соответствие;
	ПараметрыПодключения.Вставить("АдресСервера", "test-server");
	ПараметрыПодключения.Вставить("ПортСервера", 3306);

	КаталогНастроек = СоздатьКонфигВоВременномКаталоге(ПараметрыПодключения, "ПараметрыПодключения");
	УстановитьТекущийКаталог(КаталогНастроек);

	// Когда
	Поделка = Новый Поделка();
	Поделка.ЗапуститьПриложение();
	Потребитель = Поделка.НайтиЖелудь("потребительDTO");

	// Тогда
	Настройки = Потребитель.ПолучитьНастройки();
	Ожидаем.Что(Настройки, "Настройки не должны быть Неопределено").Не_().Равно(Неопределено);
	Ожидаем.Что(Настройки.АдресСервера, "АдресСервера потребителя").Равно("test-server");
	Ожидаем.Что(Настройки.ПортСервера, "ПортСервера потребителя").Равно(3306);

КонецПроцедуры

// КП-2.3: Дефолты применяются при отсутствии ключа в конфиге
&Тест
Процедура ДефолтыПрименяютсяПриОтсутствииКлюча() Экспорт

	// Дано
	ПараметрыПодключения = Новый Соответствие;
	ПараметрыПодключения.Вставить("АдресСервера", "test-server");
	// ПортСервера намеренно не указан — должен быть дефолт 8080

	КаталогНастроек = СоздатьКонфигВоВременномКаталоге(ПараметрыПодключения, "ПараметрыПодключения");
	УстановитьТекущийКаталог(КаталогНастроек);

	// Когда
	Поделка = Новый Поделка();
	Поделка.ЗапуститьПриложение();
	Желудь = Поделка.НайтиЖелудь("dto_НастройкиПодключения");

	// Тогда
	Ожидаем.Что(Желудь.АдресСервера, "АдресСервера из конфига").Равно("test-server");
	Ожидаем.Что(Желудь.ПортСервера, "ПортСервера должен быть дефолтным").Равно(8080);

КонецПроцедуры

Функция СоздатьКонфигВоВременномКаталоге(ДанныеПрефикса, Префикс)

	Данные = Новый Соответствие;
	Данные.Вставить(Префикс, ДанныеПрефикса);

	КаталогВременный = ПолучитьИмяВременногоФайла();
	СоздатьКаталог(КаталогВременный);

	ИмяФайла = ОбъединитьПути(КаталогВременный, "autumn-properties.json");
	Запись = Новый ЗаписьJSON();
	Запись.ОткрытьФайл(ИмяФайла);
	ЗаписатьJSON(Запись, Данные);
	Запись.Закрыть();

	Возврат КаталогВременный;

КонецФункции
